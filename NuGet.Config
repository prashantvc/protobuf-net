<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!--
      Ubuntu platform / targeting packs (NETStandard.Library.Ref, App.Ref, Host.linux-x64,
      Microsoft.Build.Traversal). Populate with:
        ./scripts/prepare-ubuntu-packs.sh
      or a full self-contained feed with:
        ./scripts/prepare-offline-packages.sh
    -->
    <add key="offline" value="./offline-packages" />
    <!--
      Ordinary library packages all come from nuget.org (nothing private/MyGet is required).
      Leave enabled if you have network or a nuget.org mirror.
      Comment out for fully air-gapped hosts that use a COMPLETE offline-packages feed.
    -->
    <!-- <add key="NuGet" value="https://api.nuget.org/v3/index.json" /> -->
  </packageSources>
</configuration>
